    <style name="Theme.HamzaPro.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="windowSplashScreenAnimatedIcon">@android:drawable/ic_menu_compass</item>
        <item name="postSplashScreenTheme">@style/Theme.HamzaPro</item>
    </style>
</resources>
