<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.hamza.pro.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/navigation_library"
        android:name="com.hamza.pro.LibraryFragment"
        android:label="Library"
        tools:layout="@layout/fragment_placeholder" />

    <fragment
        android:id="@+id/navigation_downloads"
        android:name="com.hamza.pro.DownloadsFragment"
        android:label="Downloads"
        tools:layout="@layout/fragment_placeholder" />

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.hamza.pro.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_placeholder" />
</navigation>
